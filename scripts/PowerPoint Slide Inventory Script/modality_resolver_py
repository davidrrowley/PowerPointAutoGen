import logging


def resolve_layout(modality, fields, registry):
    """
    Determine the most appropriate layout from the layout registry
    for the given modality and available fields.
    """

    candidates = modality_candidates().get(modality)

    if not candidates:
        raise ValueError(f"No layout candidates defined for modality '{modality}'")

    # Evaluate candidates based on fields present
    for candidate in candidates:
        layout = registry["layouts"].get(candidate)

        if not layout:
            continue

        if _fields_match_layout(fields, layout):
            logging.info(f"Resolved modality '{modality}' to layout '{candidate}'")
            return candidate

    # fallback to first candidate
    fallback = candidates[0]
    logging.warning(
        f"No strong match for modality '{modality}'. Falling back to '{fallback}'"
    )
    return fallback


def _fields_match_layout(fields, layout):
    """
    Determine whether the provided fields satisfy the placeholder
    structure required by the layout.
    """

    placeholders = layout.get("placeholders", {})

    for logical_name in placeholders.keys():

        if logical_name not in fields:
            continue

        # field exists
        return True

    return False


