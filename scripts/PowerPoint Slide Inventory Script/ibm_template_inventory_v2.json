theme: ibm
template_file: IBM_Consulting_Presentation_Template_2022_V02_Arial.potx

patterns:

  statement:
    description: "Single dominant message or opening assertion"
    candidate_layouts:
      - name: "big text"
        safe_for_automation: true
        notes: "Best opening statement layout. Strong single title zone."
        placeholders:
          title:
            type: title
            idx: 0

      - name: "cover"
        safe_for_automation: partial
        notes: "Usable for opening slides, but more presentation-cover oriented than narrative statement."
        placeholders:
          title:
            type: title
            idx: 0

      - name: "cover, image 2"
        safe_for_automation: partial
        notes: "Good for branded openers, but less useful for automated PoC narrative flow."
        placeholders:
          title:
            type: title
            idx: 0

  text_single:
    description: "Single explanatory text region with title"
    candidate_layouts:
      - name: "title, text"
        safe_for_automation: true
        notes: "Core analytical layout. Good for problem framing, chosen approach, learnings, implications."
        placeholders:
          title:
            type: title
            idx: 0
          body:
            type: body
            idx: 12

      - name: "fact, number"
        safe_for_automation: partial
        notes: "Potentially useful for results or evidence if content is concise and metric-led."
        placeholders:
          title:
            type: title
            idx: 0
          body:
            type: body
            idx: 12

  text_two_column:
    description: "Two side-by-side text regions for comparison or paired reasoning"
    candidate_layouts:
      - name: "title, text (two columns)"
        safe_for_automation: true
        notes: "Best current fit for hypothesis vs criteria, options comparison, and next steps."
        placeholders:
          title:
            type: title
            idx: 0
          body_left:
            type: body
            idx: 13
          body_right:
            type: body
            idx: 12

      - name: "title, text (two columns, different text sizes)"
        safe_for_automation: partial
        notes: "Useful where one side should dominate, but needs careful testing due to mixed placeholder types."
        placeholders:
          title:
            type: title
            idx: 0
          left:
            type: obj
            idx: 13
          right:
            type: body
            idx: 12

      - name: "case study 1: title, text (two columns), half-image"
        safe_for_automation: true
        notes: "Good richer variant where comparison needs supporting image region as well."
        placeholders:
          title:
            type: title
            idx: 0
          body_left:
            type: body
            idx: 13
          body_right:
            type: body
            idx: 15
          image:
            type: pic
            idx: 14

  text_three_or_card_comparison:
    description: "Three-part comparison or boxed option layout"
    candidate_layouts:
      - name: "boxes"
        safe_for_automation: partial
        notes: "Likely useful for options or next steps, but needs explicit placeholder testing."
        placeholders:
          title:
            type: title
            idx: 0

      - name: "insight, text, boxes"
        safe_for_automation: partial
        notes: "Promising for option cards or grouped takeaways. Needs mapping of obj placeholders."
        placeholders:
          title:
            type: title
            idx: 0

      - name: "title, text (three columns)"
        safe_for_automation: unknown
        notes: "Add if present in full template. Prefer this over forcing three options into two columns."
        placeholders: {}

  text_four_column:
    description: "Short multi-card summaries, grouped dimensions, or compact comparisons"
    candidate_layouts:
      - name: "title, text (four columns)"
        safe_for_automation: partial
        notes: "Useful for four-option summaries or grouped evidence, but content must stay very short."
        placeholders:
          title:
            type: title
            idx: 0

  image_right_text_left:
    description: "Text explanation paired with image or diagram"
    candidate_layouts:
      - name: "title, text, half-image"
        safe_for_automation: true
        notes: "Current best architecture/process layout."
        placeholders:
          title:
            type: title
            idx: 0
          body:
            type: body
            idx: 13
          image:
            type: pic
            idx: 14

      - name: "fact, number, half-image (bleeds)"
        safe_for_automation: true
        notes: "Strong option for evidence slides with a metric-led left side and supporting image on the right."
        placeholders:
          title:
            type: title
            idx: 0
          body:
            type: body
            idx: 12
          image:
            type: pic
            idx: 13

      - name: "case study 1: title, text (two columns), half-image"
        safe_for_automation: true
        notes: "Useful when both structured comparison and a hero image are needed."
        placeholders:
          title:
            type: title
            idx: 0
          body_left:
            type: body
            idx: 13
          body_right:
            type: body
            idx: 15
          image:
            type: pic
            idx: 14

  image_full:
    description: "Large image-led or diagram-led slide"
    candidate_layouts:
      - name: "title, image"
        safe_for_automation: true
        notes: "Good for clean architecture, screenshots, process visuals or hero image slides."
        placeholders:
          title:
            type: title
            idx: 0
          image:
            type: pic
            idx: 12

  facts_metrics:
    description: "Evidence, proof points, key numbers or concise results"
    candidate_layouts:
      - name: "fact, number"
        safe_for_automation: partial
        notes: "Good for one or two high-value metrics rather than narrative bullets."
        placeholders:
          title:
            type: title
            idx: 0
          body:
            type: body
            idx: 12

      - name: "fact, number, half-image (bleeds)"
        safe_for_automation: true
        notes: "Best current fit for evidence/results with supporting visual proof."
        placeholders:
          title:
            type: title
            idx: 0
          body:
            type: body
            idx: 12
          image:
            type: pic
            idx: 13

  table_structured:
    description: "Structured tabular comparison or compact evidence table"
    candidate_layouts:
      - name: "table"
        safe_for_automation: partial
        notes: "Useful where true table structure is more honest than forcing bullets."
        placeholders:
          title:
            type: title
            idx: 0

  blank_controlled:
    description: "Last-resort canvas for custom placement while retaining footer and branding"
    candidate_layouts:
      - name: "blank (with footer)"
        safe_for_automation: partial
        notes: "Only use when no structured layout fits. Prefer real layouts first."
        placeholders: {}

modality_preferences:

  context_statement:
    preferred_patterns:
      - statement

  problem_framing:
    preferred_patterns:
      - text_single

  hypothesis_success_criteria:
    preferred_patterns:
      - text_two_column

  options_considered:
    preferred_patterns:
      - text_three_or_card_comparison
      - text_four_column
      - text_two_column

  chosen_approach:
    preferred_patterns:
      - text_single

  architecture_view:
    preferred_patterns:
      - image_right_text_left
      - image_full

  evidence_results:
    preferred_patterns:
      - facts_metrics
      - table_structured
      - text_single

  learnings_constraints:
    preferred_patterns:
      - text_single
      - text_two_column

  implications:
    preferred_patterns:
      - text_single

  next_steps:
    preferred_patterns:
      - text_three_or_card_comparison
      - text_two_column